{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Metadata",
  "description": "Schema for Foomp Plugin metadata configuration",
  "type": "object",
  "properties": {
    "group": {
      "description": "The this plugin (e.g., 'org.foomp.plugins') belongs to",
      "type": "string",
      "pattern": "^([a-zA-Z_$][a-zA-Z\\d_$]*\\.)*[a-zA-Z_$][a-zA-Z\\d_$]*$"
    },
    "name": {
      "description": "The unique name of the plugin",
      "type": "string",
      "minLength": 1
    },
    "version": {
      "description": "Semantic version of the plugin (e.g., 1.0.0)",
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "contract": {
      "description": "Fully qualified class name of the plugin contract/interface",
      "type": "string",
      "pattern": "^([a-zA-Z_$][a-zA-Z\\d_$]*\\.)*[a-zA-Z_$][a-zA-Z\\d_$]*$"
    },
    "implementation": {
      "description": "Fully qualified class name of the plugin implementation",
      "type": "string",
      "pattern": "^([a-zA-Z_$][a-zA-Z\\d_$]*\\.)*[a-zA-Z_$][a-zA-Z\\d_$]*$"
    },
    "description": {
      "description": "Optional description of what the plugin does",
      "type": "string"
    }
  },
  "required": [
    "group",
    "name",
    "version",
    "contract",
    "implementation"
  ],
  "additionalProperties": false
}